# Laravel gitignore
/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
/.fleet
/.idea
/.vscode

# Compliance reports - temporary files
/compliance/*.json
/compliance/*.html
/compliance/*.xml
/compliance/*.txt
!/compliance/README.md

# Hide all markdown files except README.md
*.md
!README.md
!/compliance/README.md
